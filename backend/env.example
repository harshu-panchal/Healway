# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/healway?retryWrites=true&w=majority
# For local MongoDB: mongodb://localhost:27017/healway

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-here-change-in-production
JWT_REFRESH_EXPIRE=30d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
# Optional comma-separated allowlist for browser and mobile/webview clients
# Examples:
# CORS_ORIGINS=https://healwayy.com,https://www.healwayy.com,capacitor://localhost,ionic://localhost
CORS_ORIGINS=

# File Upload Configuration (Local Storage)
# Files are stored in backend/upload directory
# No external service required

# Email Configuration (for notifications and password reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=Healway <your-email@gmail.com>
ADMIN_NOTIFICATION_EMAILS=admin1@example.com,admin2@example.com

# OTP / SMS Configuration (SMS India Hub)
SMS_PROVIDER=SMS_INDIA
OTP_LENGTH=4
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
SMS_INDIA_HUB_API_KEY=your_api_key
SMS_INDIA_HUB_USERNAME=HEALWAY
SMS_INDIA_HUB_PASSWORD=your_password
SMS_INDIA_HUB_SENDER_ID=SMSHUB
# Optional override if your account uses a different base URL
# SMS_INDIA_HUB_BASE_URL=http://cloud.smsindiahub.in/vendorsms/pushsms.aspx
# SMS_INDIA_HUB_TIMEOUT_MS=10000

# Password Reset Configuration (Admin only)
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=30

# Admin Registration Safeguard
ADMIN_REGISTRATION_CODE=your-secure-code-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS=3600000
PASSWORD_RESET_RATE_LIMIT_MAX=3
OTP_RATE_LIMIT_WINDOW_MS=300000
OTP_RATE_LIMIT_MAX=3
# Disable OTP rate limiting for testing (set to 'true' to disable OTP requests)
DISABLE_OTP_RATE_LIMIT=false
# Disable auth rate limiting for testing (set to 'true' to disable authentication endpoints)
DISABLE_AUTH_RATE_LIMIT=false

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Commission Rates (as decimal, e.g., 0.1 = 10%, 0.2 = 20%)
# Doctor: 10% commission (90% to doctor)
DOCTOR_COMMISSION_RATE=0.1

# Redis Configuration
# Local: redis://localhost:6379
# Production: rediss://:password@host:port (use rediss:// for SSL/TLS)
REDIS_URL=redis://localhost:6379

# Socket.IO Configuration
SOCKET_IO_CORS_ORIGIN=http://localhost:3000

# File Upload Limits
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,application/pdf

# Notification Settings
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=true

# Platform Settings
PLATFORM_NAME=Healway
PLATFORM_SUPPORT_EMAIL=support@healway.com
PLATFORM_SUPPORT_PHONE=+91-1234567890

# mediasoup Configuration (for audio/video calls)
# CRITICAL: Set this to your actual public IP or domain name
# For localhost development: use your local network IP (e.g., 192.168.1.100)
# For production: use your server's public IP or domain (e.g., healway.onrender.com)
# DO NOT use 127.0.0.1 or localhost - WebRTC requires a reachable IP
PUBLIC_IP=your-server-public-ip-or-domain
MEDIA_UDP_MIN=40000
MEDIA_UDP_MAX=49999

# TURN Server (coturn) - Optional, for NAT traversal
# Format: turn:host:port (comma-separated for multiple servers)
TURN_URIS=turn:your-turn-server.com:3478
TURN_USER=your-turn-username
TURN_PASS=your-turn-password
