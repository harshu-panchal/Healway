      {/* Booking Modal */}
      <Modal
        open={showBookingModal}
        onCancel={handleCloseModal}
        footer={null}
        width={720}
        title={null}
        className="booking-modal-antd"
        centered
        destroyOnClose
        styles={{ body: { padding: '0' } }}
      >
        <div className="flex flex-col h-full max-h-[90vh]">
          {/* Custom Header */}
          <div className="flex items-center justify-between p-6 border-b border-slate-100">
            <div>
              <h2 className="text-xl font-bold text-slate-800">
                {isRescheduling ? 'Reschedule Appointment' : 'Book Appointment'}
              </h2>
              <div className="flex items-center gap-2 mt-1">
                <img 
                  src={doctor.image} 
                  alt={doctor.name} 
                  className="h-5 w-5 rounded-full object-cover"
                />
                <span className="text-sm text-slate-500">{doctor.name}</span>
              </div>
            </div>
            <button
              onClick={handleCloseModal}
              className="p-2 rounded-full hover:bg-slate-100 transition text-slate-400"
            >
              <IoCloseOutline className="h-6 w-6" />
            </button>
          </div>

          <div className="p-6 overflow-y-auto">
            <Steps 
              current={bookingStep - 1} 
              className="mb-8" 
              responsive={false}
              items={[
                { title: 'Mode', icon: <UserOutlined /> },
                { title: 'Schedule', icon: <CalendarOutlined /> },
                { title: 'Payment', icon: <CreditCardOutlined /> }
              ]}
            />

            {/* Step 1: Consultation Mode Selection */}
            {bookingStep === 1 && (
              <div className="space-y-6">
                <div className="text-center mb-6">
                  <h3 className="text-lg font-bold text-slate-800">How would you like to consult?</h3>
                  <p className="text-sm text-slate-500">Pick a mode that works best for you</p>
                </div>

                <div className="grid grid-cols-1 gap-4">
                  {/* In-Person Card */}
                  {doctor.consultationModes?.some(m => normalizeConsultationMode(m) === 'IN_PERSON') && (
                    <Card
                      hoverable
                      className={`cursor-pointer transition-all border-2 rounded-2xl ${appointmentType === 'in_person' ? 'border-primary bg-primary/5' : 'border-slate-100'}`}
                      onClick={() => setAppointmentType('in_person')}
                      styles={{ body: { padding: '20px' } }}
                    >
                      <div className="flex items-center gap-4">
                        <div className={`p-4 rounded-2xl ${appointmentType === 'in_person' ? 'bg-primary text-white' : 'bg-slate-100 text-slate-500'}`}>
                          <EnvironmentOutlined style={{ fontSize: 24 }} />
                        </div>
                        <div className="flex-1">
                          <div className="flex justify-between items-center">
                            <span className="font-bold text-slate-800 text-lg">Clinic Visit</span>
                            <Radio checked={appointmentType === 'in_person'} />
                          </div>
                          <p className="text-sm text-slate-500 mt-1">Direct consultation at the doctor's clinic</p>
                          <div className="mt-2 font-bold text-primary">₹{doctor.fees?.inPerson?.final || 0}</div>
                        </div>
                      </div>
                    </Card>
                  )}

                  {/* Call Card */}
                  {doctor.consultationModes?.some(m => normalizeConsultationMode(m) === 'CALL') && (
                    <Card
                      hoverable
                      className={`cursor-pointer transition-all border-2 rounded-2xl ${appointmentType === 'call' ? 'border-primary bg-primary/5' : 'border-slate-100'}`}
                      onClick={() => setAppointmentType('call')}
                      styles={{ body: { padding: '20px' } }}
                    >
                      <div className="flex items-center gap-4">
                        <div className={`p-4 rounded-2xl ${appointmentType === 'call' ? 'bg-indigo-500 text-white' : 'bg-slate-100 text-slate-500'}`}>
                          <IoCallOutline style={{ fontSize: 24 }} className="h-6 w-6" />
                        </div>
                        <div className="flex-1">
                          <div className="flex justify-between items-center">
                            <span className="font-bold text-slate-800 text-lg">Voice Call</span>
                            <Radio checked={appointmentType === 'call'} />
                          </div>
                          <p className="text-sm text-slate-500 mt-1">Scheduled audio consultation via app</p>
                          <div className="mt-2 font-bold text-indigo-600">₹{doctor.fees?.voiceCall?.final || 0}</div>
                        </div>
                      </div>
                    </Card>
                  )}

                  {/* Video Call Card */}
                  {doctor.consultationModes?.some(m => normalizeConsultationMode(m) === 'VIDEO') && (
                    <Card
                      hoverable
                      className={`cursor-pointer transition-all border-2 rounded-2xl ${appointmentType === 'video_call' ? 'border-primary bg-primary/5' : 'border-slate-100'}`}
                      onClick={() => setAppointmentType('video_call')}
                      styles={{ body: { padding: '20px' } }}
                    >
                      <div className="flex items-center gap-4">
                        <div className={`p-4 rounded-2xl ${appointmentType === 'video_call' ? 'bg-rose-500 text-white' : 'bg-slate-100 text-slate-500'}`}>
                          <VideoCameraOutlined style={{ fontSize: 24 }} />
                        </div>
                        <div className="flex-1">
                          <div className="flex justify-between items-center">
                            <span className="font-bold text-slate-800 text-lg">Video Meeting</span>
                            <Radio checked={appointmentType === 'video_call'} />
                          </div>
                          <p className="text-sm text-slate-500 mt-1">Face-to-face video consultation via app</p>
                          <div className="mt-2 font-bold text-rose-600">₹{doctor.fees?.videoCall?.final || 0}</div>
                        </div>
                      </div>
                    </Card>
                  )}
                </div>

                <div className="flex justify-end pt-4">
                  <Button
                    type="primary"
                    size="large"
                    className="rounded-xl h-12 px-10 font-bold"
                    onClick={handleNextStep}
                    disabled={!appointmentType}
                  >
                    Select Slot <ArrowRightOutlined />
                  </Button>
                </div>
              </div>
            )}

            {/* Step 2: Date & Slot Selection */}
            {bookingStep === 2 && (
              <div className="space-y-6">
                <div className="text-center mb-6">
                  <h3 className="text-lg font-bold text-slate-800">When should we schedule?</h3>
                  <p className="text-sm text-slate-500">Selected: {appointmentType.replace('_', ' ').toUpperCase()}</p>
                </div>

                <div className="flex gap-2 overflow-x-auto pb-4 scrollbar-hide px-1">
                  {getAvailableDates().map((date) => {
                    const isSelected = selectedDate === date.value;
                    const availability = slotAvailability[date.value];
                    const isFullyBooked = availability && !availability.available;
                    
                    return (
                      <button
                        key={date.value}
                        onClick={() => !isFullyBooked && setSelectedDate(date.value)}
                        disabled={isFullyBooked}
                        className={`flex flex-col items-center justify-center min-w-[100px] h-[100px] rounded-2xl border-2 transition-all shrink-0 ${
                          isSelected ? 'border-primary bg-primary text-white shadow-lg shadow-blue-500/20' : 
                          isFullyBooked ? 'border-red-100 bg-red-50 text-red-300 opacity-60 cursor-not-allowed' : 'border-slate-100 bg-white hover:border-slate-300 text-slate-700'
                        }`}
                      >
                        <span className={`text-[10px] font-bold uppercase tracking-wider ${isSelected ? 'text-white/70' : 'text-slate-400'}`}>{date.label.split(',')[0]}</span>
                        <span className="text-xl font-bold mt-1">{date.label.split(',')[1]}</span>
                        {isFullyBooked ? (
                          <span className="text-[10px] font-bold mt-1 uppercase text-red-500">Full</span>
                        ) : availability?.nextToken && isSelected ? (
                          <span className="text-[10px] font-bold mt-1 uppercase text-white/90">Slot #{availability.nextToken}</span>
                        ) : null}
                      </button>
                    );
                  })}
                </div>

                {selectedDate ? (
                  <Card className="rounded-2xl border-none bg-slate-50 shadow-inner">
                    <div className="space-y-4">
                      <div className="flex justify-between items-center bg-white p-3 rounded-xl border border-slate-100 shadow-sm">
                        <div className="flex items-center gap-3">
                          <div className="p-2 bg-blue-50 text-blue-500 rounded-lg">
                            <CalendarOutlined />
                          </div>
                          <span className="text-sm font-semibold text-slate-600">Selected Date</span>
                        </div>
                        <span className="font-bold text-slate-900">{dayjs(selectedDate).format('ddd, MMM D, YYYY')}</span>
                      </div>

                      {(appointmentType === 'call' || appointmentType === 'video_call') ? (
                        <>
                          <div className="flex justify-between items-center bg-white p-3 rounded-xl border border-slate-100 shadow-sm">
                            <div className="flex items-center gap-3">
                              <div className="p-2 bg-indigo-50 text-indigo-500 rounded-lg">
                                <ClockCircleOutlined />
                              </div>
                              <span className="text-sm font-semibold text-slate-600">Session Window</span>
                            </div>
                            <span className="font-bold text-slate-900">
                              {convertTo12Hour(doctor.availabilitySlots?.callVideo?.startTime)} - {convertTo12Hour(doctor.availabilitySlots?.callVideo?.endTime)}
                            </span>
                          </div>
                          <div className="flex justify-between items-center bg-white p-3 rounded-xl border border-slate-100 shadow-sm">
                            <div className="flex items-center gap-3">
                              <div className="p-2 bg-emerald-50 text-emerald-500 rounded-lg">
                                <Tag className="m-0 border-none p-0 text-emerald-500 font-bold bg-transparent">#</Tag>
                              </div>
                              <span className="text-sm font-semibold text-slate-600">Your Predicted Token</span>
                            </div>
                            <Tag color="green" className="font-bold border-none px-4 py-1 rounded-lg text-lg m-0">
                               #{slotAvailability[selectedDate]?.nextToken || 'Calculating...'}
                            </Tag>
                          </div>
                          <Alert 
                            type="info" 
                            showIcon 
                            className="rounded-xl border-none bg-blue-100/50"
                            message="Calculated Time"
                            description="Based on your token, your approximate consulting time will be assigned shortly after payment."
                          />
                        </>
                      ) : (
                        <>
                          <div className="flex justify-between items-center bg-white p-3 rounded-xl border border-slate-100 shadow-sm">
                            <div className="flex items-center gap-3">
                              <div className="p-2 bg-indigo-50 text-indigo-500 rounded-lg">
                                <ClockCircleOutlined />
                              </div>
                              <span className="text-sm font-semibold text-slate-600">Clinic Hours</span>
                            </div>
                            <span className="font-bold text-slate-900">
                              {convertTo12Hour(doctor.availabilitySlots?.inPerson?.startTime)} - {convertTo12Hour(doctor.availabilitySlots?.inPerson?.endTime)}
                            </span>
                          </div>
                          <div className="flex justify-between items-start bg-white p-3 rounded-xl border border-slate-100 shadow-sm">
                            <div className="flex items-center gap-3">
                              <div className="p-2 bg-amber-50 text-amber-500 rounded-lg">
                                <EnvironmentOutlined />
                              </div>
                              <span className="text-sm font-semibold text-slate-600">Location</span>
                            </div>
                            <span className="font-bold text-slate-900 text-right text-xs max-w-[150px]">
                              {doctor.clinicDetails?.address?.line1 || 'Clinic'}, {doctor.clinicDetails?.address?.city}
                            </span>
                          </div>
                        </>
                      )}
                    </div>
                  </Card>
                ) : (
                  <div className="h-[200px] flex flex-col items-center justify-center border-2 border-dashed border-slate-100 rounded-2xl text-slate-400">
                    <CalendarOutlined style={{ fontSize: 40 }} />
                    <p className="mt-2 font-medium">Please select a date from above</p>
                  </div>
                )}

                <div className="flex justify-between pt-4">
                  <Button
                    size="large"
                    className="rounded-xl h-12 px-8 font-semibold flex items-center gap-2 border-slate-200"
                    onClick={handlePreviousStep}
                  >
                    <ArrowLeftOutlined /> Back
                  </Button>
                  <Button
                    type="primary"
                    size="large"
                    className="rounded-xl h-12 px-10 font-bold"
                    onClick={handleNextStep}
                    disabled={!selectedDate}
                  >
                    Review Details <ArrowRightOutlined />
                  </Button>
                </div>
              </div>
            )}

            {/* Step 3: Confirmation Summary */}
            {bookingStep === 3 && (
              <div className="space-y-6">
                <div className="text-center mb-6">
                  <h3 className="text-lg font-bold text-slate-800">Final Summary</h3>
                  <p className="text-sm text-slate-500">Double check before proceeding to payment</p>
                </div>

                <Card className="rounded-2xl border-slate-100 shadow-sm overflow-hidden" styles={{ body: { padding: '0' } }}>
                  <div className="bg-slate-50 p-4 border-b border-slate-100 flex items-center justify-between">
                    <div className="flex items-center gap-3">
                      <div className={`p-2 rounded-lg text-white ${appointmentType === 'in_person' ? 'bg-purple-500' : appointmentType === 'call' ? 'bg-indigo-500' : 'bg-rose-500'}`}>
                        {appointmentType === 'in_person' ? <EnvironmentOutlined /> : appointmentType === 'call' ? <PhoneOutlined /> : <VideoCameraOutlined />}
                      </div>
                      <span className="font-bold text-slate-700 uppercase tracking-tighter decoration-indigo-500">{appointmentType.replace('_', ' ')} Consultation</span>
                    </div>
                    <Tag color="blue" className="m-0 border-none font-bold rounded-lg px-3">
                      {dayjs(selectedDate).format('MMM DD')}
                    </Tag>
                  </div>
                  
                  <div className="p-5 space-y-4">
                    <div className="flex justify-between items-center">
                      <span className="text-sm text-slate-500">Patient</span>
                      <span className="font-bold text-slate-800">Me</span>
                    </div>
                    <div className="flex justify-between items-center">
                      <span className="text-sm text-slate-500">Date</span>
                      <span className="font-bold text-slate-800">{dayjs(selectedDate).format('dddd, MMMM D, YYYY')}</span>
                    </div>
                    {(appointmentType === 'call' || appointmentType === 'video_call') && (
                      <div className="flex justify-between items-center">
                        <span className="text-sm text-slate-500">Token Number</span>
                        <Tag color="indigo" className="m-0 font-bold rounded px-2">#{slotAvailability[selectedDate]?.nextToken}</Tag>
                      </div>
                    )}
                    <div className="pt-4 border-t border-slate-100 flex justify-between items-center">
                      <span className="text-lg font-bold text-slate-700">Total Amount</span>
                      <span className="text-3xl font-black text-primary">₹{getConsultationFee(appointmentType, doctor)}</span>
                    </div>
                  </div>
                </Card>

                <div className="p-4 bg-emerald-50 rounded-2xl border border-emerald-100 flex items-start gap-3">
                  <IoCheckmarkCircle className="h-5 w-5 text-emerald-500 mt-0.5" />
                  <div className="space-y-1">
                    <p className="text-sm font-bold text-emerald-800">Instant Confirmation</p>
                    <p className="text-xs text-emerald-600">Your appointment will be booked instantly after successful payment.</p>
                  </div>
                </div>

                <div className="flex justify-between pt-4">
                  <Button
                    size="large"
                    className="rounded-xl h-12 px-8 font-semibold border-slate-200"
                    onClick={handlePreviousStep}
                  >
                    <ArrowLeftOutlined /> Back
                  </Button>
                  <Button
                    type="primary"
                    size="large"
                    className="rounded-xl h-12 flex-1 font-bold bg-emerald-600 hover:bg-emerald-700 border-none ml-4"
                    onClick={handleConfirmBooking}
                    loading={isSubmitting}
                  >
                    Pay & Confirm (₹{getConsultationFee(appointmentType, doctor)})
                  </Button>
                </div>
              </div>
            )}
          </div>
        </div>
      </Modal>
    </section>
  )
}

export default PatientDoctorDetails
